---
import { getYouTubeId, getYouTubeThumb } from '../lib/youtube';

interface Props {
  url: string;
  title?: string;
  customThumb?: string;
  class?: string;
}

const { url, title = 'Video YouTube', customThumb, class: className = '' } = Astro.props;
const id = getYouTubeId(url);
const thumb = customThumb ?? getYouTubeThumb(url, 'maxres');
---

{id && (
  <lite-youtube
    videoid={id}
    style={thumb ? `background-image: url('${thumb}');` : undefined}
    class={className}
    data-title={title}
  >
    <button type="button" class="lty-playbtn" aria-label={`Play: ${title}`}></button>
  </lite-youtube>
)}

<script>
  class LiteYTEmbed extends HTMLElement {
    connectedCallback() {
      this.addEventListener('click', () => this.activate(), { once: true });
      this.addEventListener(
        'pointerover',
        () => LiteYTEmbed.warmConnections(),
        { once: true },
      );
    }
    static warmed = false;
    static warmConnections() {
      if (LiteYTEmbed.warmed) return;
      LiteYTEmbed.warmed = true;
      const hosts = [
        'https://www.youtube-nocookie.com',
        'https://www.google.com',
        'https://googleads.g.doubleclick.net',
        'https://static.doubleclick.net',
      ];
      for (const h of hosts) {
        const l = document.createElement('link');
        l.rel = 'preconnect';
        l.href = h;
        document.head.appendChild(l);
      }
    }
    activate() {
      const id = this.getAttribute('videoid');
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.width = '560';
      iframe.height = '315';
      iframe.title = this.getAttribute('data-title') ?? 'Video YouTube';
      iframe.allow =
        'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.style.cssText =
        'position:absolute;inset:0;width:100%;height:100%;border:0;';
      this.appendChild(iframe);
      this.classList.add('lyt-activated');
    }
  }
  if (!customElements.get('lite-youtube')) {
    customElements.define('lite-youtube', LiteYTEmbed);
  }
</script>
