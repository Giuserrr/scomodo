---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import LiteYouTube from '../components/LiteYouTube.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import StatsCounter from '../components/StatsCounter.astro';

const allEpisodes = (await getCollection('episodes')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const site = await getEntry('pages', 'site');
const stats = site?.data.stats ?? {};
const settings = site?.data.settings ?? {};

const overrideSlug = settings.homepage_hero_override;
const featured =
  (overrideSlug && allEpisodes.find((e) => e.id === overrideSlug)) ||
  allEpisodes.find((e) => e.data.featured) ||
  allEpisodes[0];

const sortedAsc = [...allEpisodes].sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
const featuredNumber = featured
  ? sortedAsc.findIndex((e) => e.id === featured.id) + 1
  : 0;
const featuredFormattedDate = featured
  ? new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(featured.data.date)
  : '';

const recent = allEpisodes.filter((e) => e.id !== featured?.id).slice(0, 3);

type StatItem = { value: string; label: string; suffix?: string };
const statsItems: StatItem[] = [
  { value: stats.followers_ig ?? '7500', label: 'Follower Instagram', suffix: '+' },
  { value: stats.quarterly_views ?? '900000', label: 'Visualizzazioni trimestrali', suffix: '+' },
];
if (stats.custom_value_1 && stats.custom_label_1) {
  statsItems.push({ value: stats.custom_value_1, label: stats.custom_label_1 });
}

const podcastSeriesSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: 'Scomodo Podcast',
  description: settings.site_description,
  url: 'https://scomodo.net',
  inLanguage: 'it',
  webFeed: site?.data.contact?.youtube ?? 'https://www.youtube.com/@Scomodo_Podcast',
};
---

<BaseLayout title="Scomodo Podcast" description={settings.site_description}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(podcastSeriesSchema)} />
  </Fragment>

  {featured && (
    <section class="border-b border-[var(--color-border-subtle)]">
      <div class="mx-auto max-w-6xl px-6 pt-8 md:pt-14 pb-16 md:pb-24">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-7 text-xs uppercase tracking-[0.22em]">
          <span class="rounded-full bg-[var(--color-accent-wine)] px-3 py-1 font-medium text-[var(--color-text-primary)]">
            Nuova puntata
          </span>
          {featuredNumber > 0 && (
            <span class="text-[var(--color-accent-ocra)]">
              Ep. {String(featuredNumber).padStart(2, '0')}
            </span>
          )}
          <span class="text-[var(--color-text-muted)]" aria-hidden="true">·</span>
          <time class="text-[var(--color-text-secondary)]" datetime={featured.data.date.toISOString()}>
            {featuredFormattedDate}
          </time>
          <span class="text-[var(--color-text-muted)]" aria-hidden="true">·</span>
          <span class="text-[var(--color-text-secondary)]">{featured.data.duration}</span>
        </div>

        <div class="grid gap-10 md:grid-cols-5 md:items-start">
          <div class="md:col-span-3 order-2 md:order-1">
            <h1 class="font-display text-4xl md:text-6xl leading-[1.05] text-[var(--color-text-primary)]">
              {featured.data.title}
            </h1>

            {featured.data.description && (
              <p class="mt-5 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-xl">
                {featured.data.description}
              </p>
            )}

            {featured.data.tags.length > 0 && (
              <div class="mt-6 flex flex-wrap gap-2">
                {featured.data.tags.map((tag) => (
                  <a
                    href={`/podcast?tag=${encodeURIComponent(tag)}`}
                    class="rounded-full border border-[var(--color-border-subtle)] px-3 py-1 text-xs uppercase tracking-wider text-[var(--color-text-secondary)] hover:border-[var(--color-accent-ocra)] hover:text-[var(--color-accent-ocra)] transition-colors"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )}

            {featured.data.guests.length > 0 && (
              <div class="mt-6 flex flex-wrap items-baseline gap-x-2 gap-y-1 text-sm">
                <span class="text-xs uppercase tracking-[0.22em] text-[var(--color-text-muted)]">Con</span>
                {featured.data.guests.map((g, i) => (
                  <span class="text-[var(--color-text-primary)]">
                    {g.instagram_url ? (
                      <a href={g.instagram_url} target="_blank" rel="noopener" class="underline-offset-4 hover:text-[var(--color-accent-ocra)] hover:underline">
                        {g.name}
                      </a>
                    ) : (
                      g.name
                    )}
                    {g.role && (
                      <span class="text-[var(--color-text-secondary)]"> — {g.role}</span>
                    )}
                    {i < featured.data.guests.length - 1 && (
                      <span class="text-[var(--color-text-muted)]">,</span>
                    )}
                  </span>
                ))}
              </div>
            )}

            <div class="mt-8 flex flex-wrap gap-3">
              <a
                href={featured.data.youtube_url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 rounded bg-[var(--color-accent-wine)] px-5 py-3 text-sm font-medium text-[var(--color-text-primary)] hover:bg-[var(--color-accent-wine)]/90 transition-colors"
              >
                Guarda su YouTube
                <span aria-hidden="true">→</span>
              </a>
              {featured.data.spotify_url && (
                <a
                  href={featured.data.spotify_url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded border border-[var(--color-border-subtle)] px-5 py-3 text-sm font-medium text-[var(--color-text-primary)] hover:border-[var(--color-accent-ocra)] transition-colors"
                >
                  Ascolta su Spotify
                </a>
              )}
              <a
                href={`/podcast/${featured.id}`}
                class="inline-flex items-center gap-2 px-5 py-3 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors"
              >
                Show notes →
              </a>
            </div>
          </div>

          <div class="md:col-span-2 order-1 md:order-2 md:sticky md:top-6">
            <LiteYouTube url={featured.data.youtube_url} title={featured.data.title} />
            <p class="mt-3 text-xs text-[var(--color-text-muted)] text-center">
              {allEpisodes.length} {allEpisodes.length === 1 ? 'puntata pubblicata' : 'puntate pubblicate'} · <a href="/podcast" class="text-[var(--color-accent-ocra)] hover:opacity-80">archivio →</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  <StatsCounter items={statsItems} />

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="grid gap-12 md:grid-cols-2 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-ocra)]">
          Chi siamo
        </p>
        <h2 class="mt-4 font-display text-3xl md:text-4xl leading-tight">
          Due generazioni. Un calice. <span class="italic text-[var(--color-accent-wine)]">Zero filtri.</span>
        </h2>
        <p class="mt-5 text-[var(--color-text-secondary)] leading-relaxed">
          Marta studia Scienze Gastronomiche a Pollenzo. Massimiliano fa il ristoratore da trent'anni. Parlano di vino come si parla a tavola: con curiosità, senza reverenza, e con la libertà di dire quello che gli altri non dicono.
        </p>
        <a href="/chi-siamo" class="mt-6 inline-block text-sm text-[var(--color-accent-ocra)] border-b border-current hover:opacity-80">
          Scopri chi siamo →
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <figure class="relative aspect-[3/4] overflow-hidden rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-bg-elevated)]">
          <picture>
            <source type="image/webp" srcset="/images/team/marta-andreoli.webp" />
            <img
              src="/images/team/marta-andreoli.jpg"
              alt="Marta Andreoli"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </picture>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent" />
          <figcaption class="absolute bottom-3 left-4 font-display text-lg text-[var(--color-text-primary)]">Marta</figcaption>
        </figure>
        <figure class="relative aspect-[3/4] overflow-hidden rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-bg-elevated)] mt-8">
          <picture>
            <source type="image/webp" srcset="/images/team/massimiliano-andreoli.webp" />
            <img
              src="/images/team/massimiliano-andreoli.jpg"
              alt="Massimiliano Andreoli"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </picture>
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent" />
          <figcaption class="absolute bottom-3 left-4 font-display text-lg text-[var(--color-text-primary)]">Massimiliano</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {recent.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-end justify-between mb-10">
        <div>
          <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-ocra)]">Archivio</p>
          <h2 class="mt-2 font-display text-3xl md:text-4xl">Altre puntate</h2>
        </div>
        <a href="/podcast" class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-ocra)]">
          Vedi tutte →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {recent.map((ep) => <EpisodeCard episode={ep} />)}
      </div>
    </section>
  )}

  <section class="mx-auto max-w-6xl px-6 py-24">
    <div class="rounded-2xl border border-[var(--color-border-subtle)] bg-gradient-to-br from-[var(--color-bg-surface)] to-[var(--color-bg-elevated)] p-10 md:p-16 text-center">
      <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-ocra)]">Collaboriamo</p>
      <h2 class="mt-4 font-display text-3xl md:text-5xl leading-tight max-w-3xl mx-auto">
        La nostra audience è fatta di appassionati, ristoratori, giovani professionisti del vino.
      </h2>
      <p class="mt-5 text-[var(--color-text-secondary)] max-w-2xl mx-auto">
        {statsItems[0]?.value}+ follower Instagram, {statsItems[1]?.value}+ visualizzazioni trimestrali. Vuoi raggiungerli?
      </p>
      <a
        href="/collaboriamo"
        class="mt-8 inline-flex items-center gap-2 rounded bg-[var(--color-accent-wine)] px-6 py-3 text-sm font-medium hover:bg-[var(--color-accent-wine)]/90 transition-colors"
      >
        Parliamone
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
