---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';

const episodes = (await getCollection('episodes')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allTags = Array.from(
  new Set(episodes.flatMap((e) => e.data.tags)),
).sort();
---

<BaseLayout title="Podcast" description="Tutte le puntate di Scomodo Podcast.">
  <section class="mx-auto max-w-6xl px-6 pt-8 md:pt-12 pb-20">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-[0.25em] text-[var(--color-accent-ocra)]">Archivio</p>
      <h1 class="mt-3 font-display text-4xl md:text-6xl leading-[1.05]">Tutte le puntate</h1>
      <p class="mt-4 text-[var(--color-text-secondary)] max-w-xl" id="episode-count">
        {episodes.length} {episodes.length === 1 ? 'puntata pubblicata' : 'puntate pubblicate'}.
      </p>
    </header>

    {allTags.length > 0 && (
      <div class="mb-10 flex flex-wrap items-center gap-2" id="filters">
        <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] mr-2">Filtra:</span>
        <button type="button" data-filter="all" class="rounded border border-[var(--color-accent-ocra)] bg-[var(--color-accent-ocra)]/10 px-3 py-1 text-sm text-[var(--color-text-primary)]">
          Tutte
        </button>
        {allTags.map((tag) => (
          <button
            type="button"
            data-filter={tag}
            class="rounded border border-[var(--color-border-subtle)] px-3 py-1 text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent-ocra)] hover:text-[var(--color-text-primary)] transition-colors"
          >
            #{tag}
          </button>
        ))}
        <button
          type="button"
          id="sort-toggle"
          class="ml-auto rounded border border-[var(--color-border-subtle)] px-3 py-1 text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent-ocra)] hover:text-[var(--color-text-primary)] transition-colors"
          data-order="desc"
        >
          Più recenti ↓
        </button>
      </div>
    )}

    <div class="grid gap-6 md:grid-cols-3" id="episode-grid">
      {episodes.map((ep, i) => (
        <div data-episode data-tags={ep.data.tags.join(',')} data-date={ep.data.date.toISOString()}>
          <EpisodeCard episode={ep} eager={i < 3} />
        </div>
      ))}
    </div>

    <p id="no-results" class="mt-10 text-center text-[var(--color-text-muted)] hidden">
      Nessuna puntata corrisponde al filtro.
    </p>
  </section>
</BaseLayout>

<script>
  const grid = document.getElementById('episode-grid');
  const filtersEl = document.getElementById('filters');
  const sortBtn = document.getElementById('sort-toggle');
  const noResults = document.getElementById('no-results');
  if (grid && filtersEl) {
    const items = Array.from(grid.querySelectorAll<HTMLElement>('[data-episode]'));
    let activeFilter = 'all';

    const applyFilter = () => {
      let visible = 0;
      items.forEach((el) => {
        const tags = (el.dataset.tags ?? '').split(',').filter(Boolean);
        const show = activeFilter === 'all' || tags.includes(activeFilter);
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    };

    filtersEl.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter ?? 'all';
        filtersEl.querySelectorAll<HTMLButtonElement>('[data-filter]').forEach((b) => {
          b.classList.remove('border-[var(--color-accent-ocra)]', 'bg-[var(--color-accent-ocra)]/10', 'text-[var(--color-text-primary)]');
          b.classList.add('border-[var(--color-border-subtle)]', 'text-[var(--color-text-secondary)]');
        });
        btn.classList.remove('border-[var(--color-border-subtle)]', 'text-[var(--color-text-secondary)]');
        btn.classList.add('border-[var(--color-accent-ocra)]', 'bg-[var(--color-accent-ocra)]/10', 'text-[var(--color-text-primary)]');
        applyFilter();
      });
    });

    sortBtn?.addEventListener('click', () => {
      const current = sortBtn.dataset.order === 'desc' ? 'desc' : 'asc';
      const next = current === 'desc' ? 'asc' : 'desc';
      sortBtn.dataset.order = next;
      sortBtn.textContent = next === 'desc' ? 'Più recenti ↓' : 'Più vecchie ↑';
      const sorted = [...items].sort((a, b) => {
        const da = Date.parse(a.dataset.date ?? '');
        const db = Date.parse(b.dataset.date ?? '');
        return next === 'desc' ? db - da : da - db;
      });
      sorted.forEach((el) => grid.appendChild(el));
    });

    const url = new URL(window.location.href);
    const initialTag = url.searchParams.get('tag');
    if (initialTag) {
      const btn = filtersEl.querySelector<HTMLButtonElement>(`[data-filter="${CSS.escape(initialTag)}"]`);
      btn?.click();
    }
  }
</script>
